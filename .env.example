# ─────────────────────────────────────────────────────────────────────────────
# Roofly — root environment (used by docker compose).
# Copy to `.env` and fill in real values for local dev.
# Per-service envs live in backend/.env and frontend/.env (also gitignored).
# ─────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=roofly

# Ports exposed on the host
FRONTEND_PORT=3000
BACKEND_PORT=8000
NGINX_PORT=80
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MySQL
MYSQL_DATABASE=roofly
MYSQL_USER=roofly
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

# Redis
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_DEFAULT_USER=roofly
RABBITMQ_DEFAULT_PASS=roofly

# ─────────────────────────────────────────────────────────────────────────────
# Frontend per-environment flags
#
# These drive UI behaviour via composables/useEnv.ts. Each VPS clone overrides
# them in its own .env (gitignored). Unset = production defaults — safe to leave
# empty on prod, must be set on demo.
#
# Per-environment values:
#
#   demo.roofly.my   (~/roofly-demo/.env on VPS)
#     NUXT_PUBLIC_APP_ENV=demo
#     NUXT_PUBLIC_USE_MOCK=true
#     NUXT_PUBLIC_DEMO_FEEDBACK_URL=https://forms.google.com/your-form-id
#
#   uat.roofly.my    (~/roofly-uat/.env on VPS)
#     NUXT_PUBLIC_APP_ENV=uat
#     (others use defaults — no mocks, no demo widgets)
#
#   roofly.my        (~/roofly/.env on VPS, prod)
#     leave empty / file may not exist — defaults handle it
#
# Local dev (Mac mini): uncomment the demo block below if you want to preview
# the demo experience locally; otherwise leave empty for prod-like behaviour.
# ─────────────────────────────────────────────────────────────────────────────

NUXT_PUBLIC_APP_ENV=
NUXT_PUBLIC_USE_MOCK=
NUXT_PUBLIC_DEMO_FEEDBACK_URL=
