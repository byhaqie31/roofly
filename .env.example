# ─────────────────────────────────────────────────────────────────────────────
# Roofly — root environment (used by docker compose).
# Copy to `.env` and fill in real values.
#
# Phase 2 scope: frontend-only (mocks, no backend yet).
# MySQL / Redis / RabbitMQ vars come back when Phase 3 (backend) lands.
# ─────────────────────────────────────────────────────────────────────────────

# Used as the docker compose project namespace. Change per VPS clone so
# containers from demo / uat / prod don't collide on the same host.
#   demo.roofly.my   → demo-roofly
#   uat.roofly.my    → uat-roofly
#   roofly.my        → roofly
COMPOSE_PROJECT_NAME=roofly

# Host port the frontend container is published on. Each VPS clone uses a
# different port so multiple environments run side-by-side.
#   demo.roofly.my   → 3001
#   uat.roofly.my    → 3003
#   roofly.my        → 3002
#   local dev        → 3000
FRONTEND_PORT=3000

# App-environment identifier — drives all UI feature flags via useEnv().
# Values: "demo" | "uat" | "production". Unset defaults to production
# (safe — never accidentally serves demo widgets to real customers).
#   demo.roofly.my   → demo
#   uat.roofly.my    → uat
#   roofly.my        → leave empty
NUXT_PUBLIC_APP_ENV=

# Force frontend services to return mock data instead of calling the API.
# Demo always uses mocks regardless of this flag (useEnv derives it).
#   demo.roofly.my   → true
#   uat / prod       → false (or leave empty)
NUXT_PUBLIC_USE_MOCK=

# Floating feedback widget on demo.roofly.my opens this URL in a new tab.
# Empty = widget hidden. Only used when APP_ENV=demo.
NUXT_PUBLIC_DEMO_FEEDBACK_URL=https://forms.gle/ppNGGSC2cZXutpx18
