# ─────────────────────────────────────────────────────────────────────────────
# Hauz — root environment (used by docker compose).
# Copy to `.env` and fill in real values for local dev.
# Per-service envs live in backend/.env and frontend/.env (also gitignored).
# ─────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=hauz

# Ports exposed on the host
FRONTEND_PORT=3000
BACKEND_PORT=8000
NGINX_PORT=80
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MySQL
MYSQL_DATABASE=hauz
MYSQL_USER=hauz
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

# Redis
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_DEFAULT_USER=hauz
RABBITMQ_DEFAULT_PASS=hauz
